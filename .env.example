# Copy to .env.local (gitignored) and fill in. Never commit real values.

# Etherscan multichain API key (chainid 143 = Monad). Powers lifetime gas totals,
# full activity history, NFT holdings, and approval history. Without it the app
# still runs but those sections fall back to a limited RPC-only view.
# Free key: https://etherscan.io/apidashboard
ETHERSCAN_API_KEY=

# Only needed to deploy the MonScopeLens contract (node scripts/deploy.mjs).
# A funded Monad deployer key. Never commit this. Not needed to run the app.
PRIVATE_KEY=
